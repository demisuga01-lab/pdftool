# Backend environment configuration. Copy this file to backend/.env and edit
# for the target environment.
# Do not commit backend/.env.

REDIS_URL=redis://localhost:6379/0

DATA_DIR=/opt/pdftool/data
UPLOAD_DIR=/opt/pdftool/data/uploads
OUTPUT_DIR=/opt/pdftool/data/outputs
TEMP_DIR=/opt/pdftool/data/temp

# Public launch policy: keep this at 25 MB unless launch policy changes.
MAX_FILE_SIZE_MB=25
MAX_BATCH_BYTES=104857600
MAX_ARCHIVE_EXTRACTED_BYTES=104857600
MAX_ARCHIVE_FILES=200

# Files are retained for FILE_RETENTION_HOURS=24.
FILE_RETENTION_HOURS=24

# Local development may add http://localhost:3000 to ALLOWED_ORIGINS.
# Production should use ALLOWED_ORIGINS=https://tools.wellfriend.online.
ALLOWED_ORIGINS=https://tools.wellfriend.online

RATE_LIMIT_ENABLED=true
# Rate limiting is per tool bucket. Status polling and previews use a higher
# bucket so active jobs do not look failed just because the UI checked status.
RATE_LIMIT_GLOBAL_PER_HOUR=200
RATE_LIMIT_JOBS_PER_HOUR=40
RATE_LIMIT_UPLOADS_PER_HOUR=60
RATE_LIMIT_STATUS_PER_HOUR=1000
RATE_LIMIT_DOWNLOADS_PER_HOUR=200
RATE_LIMIT_REDIS_URL=redis://localhost:6379/0

# RATE_LIMIT_TRUST_PROXY=true is only correct behind a trusted reverse proxy.
# If backend port 8000 is directly exposed publicly, firewall it or set
# RATE_LIMIT_TRUST_PROXY=false.
RATE_LIMIT_TRUST_PROXY=true
